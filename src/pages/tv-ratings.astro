---
import "../styles/global.css";

const name = "Paras Goel";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>TV Show Ratings | {name}</title>
  </head>

  <body class="min-h-screen bg-black text-white selection:bg-white/20">
    <!-- Background: neon radials + subtle grid -->
    <div class="fixed inset-0 -z-10">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_15%_20%,rgba(99,102,241,0.35),transparent_38%),radial-gradient(circle_at_85%_25%,rgba(34,211,238,0.22),transparent_45%),radial-gradient(circle_at_50%_85%,rgba(236,72,153,0.18),transparent_52%)]"
      />
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:48px_48px] opacity-20"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black to-black" />
    </div>

    <main class="mx-auto max-w-5xl px-6 py-14">
      <!-- Top bar -->
      <header class="flex items-center justify-between">
        <a href="/" class="text-xs tracking-[0.3em] text-white/60 hover:text-white/80 transition">
          ← BACK TO PORTFOLIO
        </a>
      </header>

      <!-- Hero -->
      <section class="mt-16">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs text-white/70 backdrop-blur"
        >
          <span class="h-2 w-2 rounded-full bg-yellow-400"></span>
          IMDB Ratings via OMDb API
        </div>

        <h1 class="mt-6 text-4xl font-semibold leading-tight">
          TV Show Ratings
          <span class="block text-white/55">Search any show, get IMDB scores</span>
        </h1>

        <!-- Search Box -->
        <div class="mt-8 relative">
          <input
            type="text"
            id="search-input"
            placeholder="Search for a TV show..."
            class="w-full rounded-2xl border border-white/15 bg-white/5 px-6 py-4 text-lg text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 focus:bg-white/10 backdrop-blur transition"
          />
          <button
            id="search-btn"
            class="absolute right-2 top-1/2 -translate-y-1/2 rounded-xl bg-white px-5 py-2.5 text-sm font-medium text-black hover:bg-white/90 transition"
          >
            Search
          </button>
        </div>

        <!-- API Key Notice -->
        <div id="api-key-notice" class="mt-4 rounded-xl border border-yellow-500/30 bg-yellow-500/10 p-4 text-sm text-yellow-200/80">
          ⚠️ <strong>Setup required:</strong> Add your OMDb API key in the script below. Get a free key at 
          <a href="http://www.omdbapi.com/apikey.aspx" target="_blank" class="underline hover:text-yellow-200">omdbapi.com</a>
        </div>

        <!-- Loading State -->
        <div id="loading" class="hidden mt-8 text-center">
          <div class="inline-block h-8 w-8 animate-spin rounded-full border-4 border-white/20 border-t-white"></div>
          <p class="mt-2 text-white/60">Searching...</p>
        </div>

        <!-- Error State -->
        <div id="error" class="hidden mt-8 rounded-2xl border border-red-500/30 bg-red-500/10 p-6 text-center">
          <p class="text-red-200" id="error-message">Something went wrong</p>
        </div>

        <!-- Results Container -->
        <div id="results" class="mt-8 grid gap-6 sm:grid-cols-2">
          <!-- Results will be injected here -->
        </div>

        <!-- Show Detail Modal/Expanded View -->
        <div id="show-detail" class="hidden mt-8">
          <!-- Detail will be injected here -->
        </div>
      </section>

      <footer class="mt-20 border-t border-white/10 pt-8 text-sm text-white/50">
        Data provided by <a href="http://www.omdbapi.com/" target="_blank" class="underline hover:text-white/70">OMDb API</a>. 
        IMDB ratings are property of IMDb.com, Inc.
      </footer>
    </main>

    <script>
      // ============================================
      // 🔑 PASTE YOUR OMDB API KEY HERE
      // Get a free key at: http://www.omdbapi.com/apikey.aspx
      // ============================================
      const OMDB_API_KEY = "ef616b54";
      // ============================================

      const searchInput = document.getElementById("search-input") as HTMLInputElement;
      const searchBtn = document.getElementById("search-btn");
      const resultsContainer = document.getElementById("results");
      const loadingEl = document.getElementById("loading");
      const errorEl = document.getElementById("error");
      const errorMessage = document.getElementById("error-message");
      const showDetailEl = document.getElementById("show-detail");
      const apiKeyNotice = document.getElementById("api-key-notice");

      // Hide API key notice if key is set
      if (OMDB_API_KEY && OMDB_API_KEY !== "YOUR_API_KEY_HERE") {
        apiKeyNotice?.classList.add("hidden");
      }

      function showLoading() {
        loadingEl?.classList.remove("hidden");
        errorEl?.classList.add("hidden");
        resultsContainer!.innerHTML = "";
        showDetailEl?.classList.add("hidden");
      }

      function hideLoading() {
        loadingEl?.classList.add("hidden");
      }

      function showError(message: string) {
        hideLoading();
        errorEl?.classList.remove("hidden");
        if (errorMessage) errorMessage.textContent = message;
      }

      function hideError() {
        errorEl?.classList.add("hidden");
      }

      async function searchShows(query: string) {
        if (!query.trim()) return;
        
        if (OMDB_API_KEY === "YOUR_API_KEY_HERE") {
          showError("Please add your OMDb API key in the script section of tv-ratings.astro");
          return;
        }

        showLoading();
        hideError();

        try {
          // Search for TV series
          const response = await fetch(
            `https://www.omdbapi.com/?apikey=${OMDB_API_KEY}&s=${encodeURIComponent(query)}&type=series`
          );
          const data = await response.json();

          hideLoading();

          if (data.Response === "False") {
            showError(data.Error || "No shows found. Try a different search term.");
            return;
          }

          displayResults(data.Search);
        } catch (err) {
          hideLoading();
          showError("Failed to fetch data. Please check your internet connection.");
        }
      }

      function displayResults(shows: any[]) {
        if (!resultsContainer) return;

        resultsContainer.innerHTML = shows
          .map(
            (show) => `
          <button
            onclick="getShowDetails('${show.imdbID}')"
            class="group text-left rounded-2xl border border-white/10 bg-white/5 p-4 backdrop-blur hover:bg-white/10 transition cursor-pointer"
          >
            <div class="flex gap-4">
              <img
                src="${show.Poster !== "N/A" ? show.Poster : "/image_not_load.png"}"
                alt="${show.Title}"
                class="w-16 h-24 object-cover rounded-lg flex-shrink-0"
                onerror="this.onerror=null; this.src='/image_not_load.png';"
              />
              <div class="flex-1 min-w-0">
                <div class="font-medium text-white group-hover:text-white/90 truncate">${show.Title}</div>
                <div class="text-sm text-white/50 mt-1">${show.Year}</div>
                <div class="mt-2 text-xs text-white/40">Click for rating →</div>
              </div>
            </div>
          </button>
        `
          )
          .join("");
      }

      // Make getShowDetails available globally
      (window as any).getShowDetails = async function (imdbID: string) {
        showLoading();
        resultsContainer!.innerHTML = "";

        try {
          const response = await fetch(
            `https://www.omdbapi.com/?apikey=${OMDB_API_KEY}&i=${imdbID}&plot=full`
          );
          const show = await response.json();

          hideLoading();

          if (show.Response === "False") {
            showError("Could not fetch show details.");
            return;
          }

          displayShowDetail(show);
        } catch (err) {
          hideLoading();
          showError("Failed to fetch show details.");
        }
      };

      function displayShowDetail(show: any) {
        if (!showDetailEl) return;

        showDetailEl.classList.remove("hidden");
        showDetailEl.innerHTML = `
          <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur">
            <button
              onclick="document.getElementById('show-detail')?.classList.add('hidden')"
              class="text-sm text-white/50 hover:text-white mb-4 transition"
            >
              ← Back to results
            </button>
            
            <div class="flex flex-col sm:flex-row gap-6">
              <img
                src="${show.Poster !== "N/A" ? show.Poster : "/image_not_load.png"}"
                alt="${show.Title}"
                class="w-40 h-60 object-cover rounded-xl flex-shrink-0 mx-auto sm:mx-0"
                onerror="this.onerror=null; this.src='/image_not_load.png';"
              />
              
              <div class="flex-1">
                <h2 class="text-2xl font-semibold">${show.Title}</h2>
                <div class="text-white/50 mt-1">${show.Year} • ${show.totalSeasons ? show.totalSeasons + " Seasons" : "TV Series"}</div>
                
                <!-- IMDB Rating - The main attraction! -->
                <div class="mt-4 inline-flex items-center gap-3 rounded-xl border border-yellow-500/30 bg-yellow-500/10 px-4 py-3">
                  <svg class="w-8 h-8 text-yellow-400" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  <div>
                    <div class="text-2xl font-bold text-yellow-400">${show.imdbRating !== "N/A" ? show.imdbRating : "N/A"}<span class="text-lg text-yellow-400/60">/10</span></div>
                    <div class="text-xs text-white/50">${show.imdbVotes !== "N/A" ? show.imdbVotes + " votes" : "IMDB Rating"}</div>
                  </div>
                </div>
                
                <!-- Other ratings if available -->
                ${show.Ratings && show.Ratings.length > 1 ? `
                  <div class="mt-3 flex flex-wrap gap-2">
                    ${show.Ratings.filter((r: any) => r.Source !== "Internet Movie Database").map((r: any) => `
                      <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/70">
                        ${r.Source}: ${r.Value}
                      </span>
                    `).join("")}
                  </div>
                ` : ""}
                
                <div class="mt-4 flex flex-wrap gap-2">
                  ${show.Genre ? show.Genre.split(", ").map((g: string) => `
                    <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/70">${g}</span>
                  `).join("") : ""}
                </div>
                
                <p class="mt-4 text-sm text-white/70 leading-relaxed">${show.Plot !== "N/A" ? show.Plot : "No plot summary available."}</p>
                
                <div class="mt-4 text-sm text-white/50">
                  ${show.Actors !== "N/A" ? `<div><strong class="text-white/70">Cast:</strong> ${show.Actors}</div>` : ""}
                  ${show.Director !== "N/A" ? `<div class="mt-1"><strong class="text-white/70">Director:</strong> ${show.Director}</div>` : ""}
                </div>
                
                <a
                  href="https://www.imdb.com/title/${show.imdbID}/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 mt-4 text-sm text-yellow-400 hover:text-yellow-300 transition"
                >
                  View on IMDB ↗
                </a>
              </div>
            </div>
          </div>
        `;
      }

      // Event listeners
      searchBtn?.addEventListener("click", () => searchShows(searchInput.value));
      searchInput?.addEventListener("keypress", (e) => {
        if (e.key === "Enter") searchShows(searchInput.value);
      });
    </script>
  </body>
</html>
