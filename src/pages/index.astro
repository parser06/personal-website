---
import "../styles/global.css";

import ParallaxBackground from "../components/ParallaxBackground.astro";

const name = "Paras Goel";
const tagline = "Coming soon.";
const links = [
  { label: "GitHub", href: "https://github.com/" },
  { label: "LinkedIn", href: "https://linkedin.com/" },
  { label: "Email", href: "mailto:you@example.com" },
];

const projects = [
  {
    title: "Project One",
    desc: "Coming soon.",
    href: "#",
    tags: ["ML", "Systems", "Research"],
  },
  {
    title: "Project Two",
    desc: "Coming soon.",
    href: "#",
    tags: ["Robotics", "Infra"],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{name}</title>
  </head>

  <body class="min-h-screen bg-black text-white selection:bg-white/20">
    <!-- Background: neon radials + subtle grid -->
	<!-- Depreciated background
    <div class="fixed inset-0 -z-10">
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_15%_20%,rgba(99,102,241,0.35),transparent_38%),radial-gradient(circle_at_85%_25%,rgba(34,211,238,0.22),transparent_45%),radial-gradient(circle_at_50%_85%,rgba(236,72,153,0.18),transparent_52%)]"
      />
      <div
        class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:48px_48px] opacity-20"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black to-black" />
    </div>
	-->

	<ParallaxBackground />

    <main class="mx-auto max-w-5xl px-6 py-14">
      <!-- Top bar -->
      <header class="flex items-center justify-between">
        <div class="text-xs tracking-[0.3em] text-white/60">
          SYSTEM // PORTFOLIO
        </div>

        <nav class="hidden sm:flex items-center gap-7 text-sm text-white/70">
          <a class="hover:text-white" href="#projects">Projects</a>
          <a class="hover:text-white" href="#about">About</a>
          <a class="hover:text-white" href="#contact">Contact</a>
          <a class="hover:text-white" href="/tv-ratings">TV Ratings</a>
        </nav>
      </header>

      <!-- Hero -->
      <section class="mt-20">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs text-white/70 backdrop-blur"
        >
          <span class="h-2 w-2 rounded-full bg-white/60"></span>
          Local preview — not deployed
        </div>

        <h1 class="mt-6 text-5xl font-semibold leading-tight">
          {name}
          <span class="block text-white/55">Coming soon</span>
        </h1>

        <p class="mt-6 max-w-2xl text-lg text-white/70">
          {tagline}. Coming soon.
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="#projects"
            class="rounded-xl bg-white px-5 py-3 text-sm font-medium text-black hover:bg-white/90"
          >
            View projects
          </a>
          <a
            href="#contact"
            class="rounded-xl border border-white/15 bg-white/5 px-5 py-3 text-sm font-medium text-white hover:bg-white/10 backdrop-blur"
          >
            Contact
          </a>
          {links.map((l) => (
            <a
              href={l.href}
              class="rounded-xl border border-white/10 bg-white/0 px-5 py-3 text-sm text-white/70 hover:bg-white/5 hover:text-white transition"
              target={l.href.startsWith("http") ? "_blank" : undefined}
              rel={l.href.startsWith("http") ? "noreferrer" : undefined}
            >
              {l.label} ↗
            </a>
          ))}
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          {["Coming soon", "Coming soon.", "Coming soon."].map((x) => (
            <div class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
              <div class="text-xs tracking-[0.25em] text-white/55">MODULE</div>
              <div class="mt-2 text-xl font-medium">{x}</div>
              <div class="mt-2 text-sm text-white/60">
                Coming soon.
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Projects -->
      <section id="projects" class="mt-24">
        <div class="flex items-end justify-between gap-4">
          <h2 class="text-2xl font-semibold">Projects</h2>
          <div class="text-sm text-white/60">Selected work</div>
        </div>

        <div class="mt-6 grid gap-6 sm:grid-cols-2">
          {projects.map((p) => (
            <a
              href={p.href}
              class="group rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur hover:bg-white/10 transition"
            >
              <div class="flex items-center justify-between">
                <div class="text-lg font-medium">{p.title}</div>
                <div class="text-white/50 group-hover:text-white/80">↗</div>
              </div>
              <div class="mt-2 text-sm text-white/60">{p.desc}</div>
              <div class="mt-4 flex flex-wrap gap-2">
                {p.tags.map((t) => (
                  <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-white/70">
                    {t}
                  </span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- About -->
      <section id="about" class="mt-24">
        <h2 class="text-2xl font-semibold">About</h2>
        <div class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur">
          <p class="text-white/70">
            Coming soon.
          </p>
        </div>
      </section>

      <!-- Contact -->
      <section id="contact" class="mt-24 mb-10">
        <h2 class="text-2xl font-semibold">Contact</h2>
        <div class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur">
          <p class="text-white/70">
            Coming soon.
          </p>
        </div>
      </section>

      <footer class="mt-10 border-t border-white/10 pt-8 text-sm text-white/50">
        © {new Date().getFullYear()} {name}. Built with Astro + Tailwind.
      </footer>
    </main>
  </body>
</html>
