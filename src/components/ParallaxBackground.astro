<canvas id="bg" class="fixed inset-0 -z-10 h-full w-full"></canvas>

<script is:inline>
  const canvas = document.getElementById("bg");
  const ctx = canvas.getContext("2d", { alpha: true });

  // Respect reduced motion
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  let w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);

  function resize() {
    w = window.innerWidth;
    h = window.innerHeight;
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = Math.floor(w * dpr);
    canvas.height = Math.floor(h * dpr);
    canvas.style.width = w + "px";
    canvas.style.height = h + "px";
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }
  window.addEventListener("resize", resize);
  resize();

  // Camera follow (mouse -> target -> eased actual)
  const target = { x: 0, y: 0 };
  const cam = { x: 0, y: 0 };

  window.addEventListener("pointermove", (e) => {
    // normalized -0.5..0.5
    const nx = (e.clientX / w) - 0.5;
    const ny = (e.clientY / h) - 0.5;
    target.x = nx;
    target.y = ny;
  }, { passive: true });

  // Particles with "depth" for parallax
  const N = 180;
  const particles = Array.from({ length: N }, () => {
    const z = Math.random(); // 0..1 depth
    return {
      x: Math.random() * w,
      y: Math.random() * h,
      vx: (Math.random() - 0.5) * (0.25 + 0.75 * z),
      vy: (Math.random() - 0.5) * (0.25 + 0.75 * z),
      z,
      r: 0.6 + 1.8 * z,
    };
  });

  function step() {
    if (reduceMotion) {
      ctx.clearRect(0, 0, w, h);
      return; // keep it static if user prefers reduced motion
    }

    // Smooth camera: ease toward target
    cam.x += (target.x - cam.x) * 0.06;
    cam.y += (target.y - cam.y) * 0.06;

    ctx.clearRect(0, 0, w, h);

    // Subtle background glow that also follows the "camera"
    const gx = w * (0.5 + cam.x * 0.18);
    const gy = h * (0.5 + cam.y * 0.18);
    const grad = ctx.createRadialGradient(gx, gy, 0, gx, gy, Math.max(w, h) * 0.7);
    grad.addColorStop(0, "rgba(99,102,241,0.20)");
    grad.addColorStop(0.35, "rgba(34,211,238,0.12)");
    grad.addColorStop(1, "rgba(0,0,0,0)");
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, w, h);

    // Draw particles
    for (const p of particles) {
      // Drift
      p.x += p.vx;
      p.y += p.vy;

      // Wrap
      if (p.x < -20) p.x = w + 20;
      if (p.x > w + 20) p.x = -20;
      if (p.y < -20) p.y = h + 20;
      if (p.y > h + 20) p.y = -20;

      // Parallax: nearer particles move more with camera
      const par = (0.5 + p.z * 1.6);
      const ox = cam.x * 60 * par;
      const oy = cam.y * 60 * par;

      ctx.beginPath();
      ctx.arc(p.x + ox, p.y + oy, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${0.10 + 0.25 * p.z})`;
      ctx.fill();
    }

    // Optional: faint connecting lines (adds “field” feel)
    // keep it light: only connect close neighbors
    for (let i = 0; i < particles.length; i++) {
      const a = particles[i];
      for (let j = i + 1; j < particles.length; j++) {
        const b = particles[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const dist2 = dx*dx + dy*dy;
        if (dist2 < 140*140) {
          const t = 1 - Math.sqrt(dist2) / 140;
          ctx.strokeStyle = `rgba(255,255,255,${0.06 * t})`;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(a.x + cam.x * 60 * (0.5 + a.z * 1.6), a.y + cam.y * 60 * (0.5 + a.z * 1.6));
          ctx.lineTo(b.x + cam.x * 60 * (0.5 + b.z * 1.6), b.y + cam.y * 60 * (0.5 + b.z * 1.6));
          ctx.stroke();
        }
      }
    }

    requestAnimationFrame(step);
  }

  requestAnimationFrame(step);
</script>
